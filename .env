SESSION_ID=Gifted~

# Language: en (English), fr (French), cr (Créole), es (Español), pt (Português), hi (Hindi), si (Sinhala)
LANGUAGE=en

# Bot mode: public or private
MODE=public

# Your timezone e.g. Africa/Nairobi, America/New_York, Asia/Kolkata
TIME_ZONE=America/Sao_Paulo

# Auto-like and auto-view WhatsApp statuses
AUTO_LIKE_STATUS=true
AUTO_READ_STATUS=true

# PostgreSQL connection URL (optional - falls back to SQLite if empty)
DATABASE_URL=
